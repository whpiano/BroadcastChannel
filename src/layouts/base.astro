---
import '../styles/app.css'
import { SEO } from 'astro-seo'
import BackToTop from '../components/BackToTop.astro'
import Header from '../components/header.astro'
import NavSidebar from '../components/NavSidebar.astro'
import SiteFooter from '../components/SiteFooter.astro'
import { getEnv, parseDelimitedItems } from '../lib/env'
import { getPageSeo } from '../lib/seo'
import type { ChannelInfo, SeoMeta } from '../types'

const { SITE_URL, RSS_URL, RSS_PREFIX } = Astro.locals
const { channel, pageType, seo } = Astro.props as {
  channel: ChannelInfo
  pageType: 'home' | 'blog' | 'post' | 'page'
  seo?: SeoMeta
}

const locale = getEnv(import.meta.env, Astro, 'LOCALE')
const twitter = getEnv(import.meta.env, Astro, 'TWITTER')
const { currentPathname, hasCustomTitle, linksPathname, seoParams, siteRootPathname, siteTitle, tagsPathname } =
  getPageSeo({
    Astro,
    channel,
    locale,
    seo,
    siteUrl: SITE_URL,
  })

const GOOGLE_SEARCH_SITE = getEnv(import.meta.env, Astro, 'GOOGLE_SEARCH_SITE')
const searchAction = GOOGLE_SEARCH_SITE ? 'https://www.google.com/search' : `${SITE_URL}search/result`

const HEADER_INJECT = getEnv(import.meta.env, Astro, 'HEADER_INJECT')
const FOOTER_INJECT = getEnv(import.meta.env, Astro, 'FOOTER_INJECT')
const TAGS = getEnv(import.meta.env, Astro, 'TAGS')
const LINKS = getEnv(import.meta.env, Astro, 'LINKS')
const navs = parseDelimitedItems(getEnv(import.meta.env, Astro, 'NAVS'))

const skipLinkText = 'Skip to main content'
---

<!doctype html>
<html lang={locale ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="alternate" type="application/rss+xml" title={`${RSS_PREFIX}${channel?.title}`} href={RSS_URL} />
    <SEO
      titleTemplate={hasCustomTitle ? `%s | ${siteTitle}` : undefined}
      titleDefault={siteTitle || seoParams.description}
      twitter={{
        card: 'summary_large_image',
        creator: twitter ? `@${twitter}` : undefined,
      }}
      {...seoParams}
    />
    <Fragment set:html={HEADER_INJECT} />
  </head>

  <body class={pageType}>
    <a href="#main-content" class="skip-link">{skipLinkText}</a>
    <Header channel={channel} />
    <NavSidebar
      channelTitle={channel?.title}
      currentPathname={currentPathname}
      googleSearchSite={GOOGLE_SEARCH_SITE}
      linksPathname={linksPathname}
      navs={navs}
      searchAction={searchAction}
      showLinks={Boolean(LINKS)}
      showTags={Boolean(TAGS)}
      siteRootPathname={siteRootPathname}
      siteUrl={SITE_URL}
      tagsPathname={tagsPathname}
    />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
    <BackToTop />
    <Fragment set:html={FOOTER_INJECT} />
  </body>
</html>
