---
import List from '../../components/list.astro'
import { getSearchQuery, getSearchSeo } from '../../lib/search'
import { getChannelInfo } from '../../lib/telegram'

const q = getSearchQuery(Astro)
const channel = await getChannelInfo(Astro, {
  q,
})
const pageSeo = getSearchSeo(q)
---

<List channel={channel} before={false} after={false} pageHeading={`Search: ${q}`} pageSeo={pageSeo} />
