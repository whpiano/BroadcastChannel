---
import BaseLayout from '../layouts/BaseLayout.astro'
import DirectorySection from '../components/DirectorySection.astro'
import { getChannelInfo } from '../lib/telegram'
import { getEnv, parseDelimitedItems } from '../lib/env'

const channel = await getChannelInfo()
const pageSeo = { title: 'Links' }
const links = parseDelimitedItems(getEnv(import.meta.env, 'LINKS'))

if (!links.length) {
  return Astro.redirect('/')
}

const items = links.map((link) => ({
  href: link.href,
  label: link.title,
  title: link.title,
  external: true,
}))
---

<BaseLayout channel={channel} seo={pageSeo} pageType="page">
  <DirectorySection id="links" title="Links" items={items} />
</BaseLayout>
