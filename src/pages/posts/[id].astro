---
import PostsPage from '../../components/PostsPage.astro'
import { getChannelInfo, getChannelPost } from '../../lib/telegram'

const channelInfo = await getChannelInfo()

if (!Astro.params.id) {
  return Astro.redirect('/')
}

const post = channelInfo.posts.find((item) => item.id === Astro.params.id) ?? (await getChannelPost(Astro.params.id))

if (!post) {
  return new Response('Not Found', {
    status: 404,
    headers: {
      'Cache-Control': 'public, max-age=300, s-maxage=300',
    },
  })
}

const channel = {
  ...(channelInfo || {}),
  posts: [post],
}
---

<PostsPage
  channel={channel}
  before={false}
  after={false}
  isDetail={true}
  pageHeading={post.title || channel.title}
  pageSeo={post}
  pageType="post"
/>
