---
import PostsPage from '../../components/PostsPage.astro'
import { getChannelInfo } from '../../lib/telegram'
import type { SeoMeta } from '../../types'

const channel = await getChannelInfo({
  after: Astro.params.cursor,
})
const pageSeo: SeoMeta = {
  noindex: true,
}
---

<PostsPage channel={channel} pageClass="feed" pageHeading={channel.title} pageSeo={pageSeo} pageType="home" />
