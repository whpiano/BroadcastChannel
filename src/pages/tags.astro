---
import BaseLayout from '../layouts/BaseLayout.astro'
import DirectorySection from '../components/DirectorySection.astro'
import { getChannelInfo } from '../lib/telegram'
import { getEnv, parseCsvList } from '../lib/env'

const channel = await getChannelInfo()
const pageSeo = { title: 'Tags' }
const items = parseCsvList(getEnv(import.meta.env, 'TAGS')).map((tag) => ({
  href: `/search/result?q=${encodeURIComponent(`#${tag}`)}`,
  label: tag,
}))
---

<BaseLayout channel={channel} seo={pageSeo} pageType="page">
  <DirectorySection id="tags" title="Tags" items={items} />
</BaseLayout>
