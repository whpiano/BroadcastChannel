{
  "name": "broadcast-channel",
  "type": "module",
  "version": "0.2.1",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "test -d .git && simple-git-hooks || true"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/netlify": "^8.1.2",
    "@astrojs/node": "^11.0.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/vercel": "^11.0.3",
    "@edgeone/astro": "^1.1.4",
    "@iconify-json/ri": "^1.2.10",
    "@tailwindcss/vite": "^4.3.2",
    "@types/prismjs": "^1.26.6",
    "astro": "^7.0.9",
    "astro-eslint-parser": "^3.0.0",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0",
    "baseline-browser-mapping": "^2.10.43",
    "cheerio": "1.0.0-rc.12",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.0",
    "eslint-plugin-format": "^2.0.1",
    "flourite": "^1.3.0",
    "lint-staged": "^17.0.8",
    "ocache": "^0.2.0",
    "ofetch": "^1.5.1",
    "prettier-plugin-astro": "^0.14.1",
    "prismjs": "^1.30.0",
    "prismjs-components-importer": "^0.2.0",
    "sanitize-html": "^2.17.6",
    "simple-git-hooks": "^2.13.1",
    "std-env": "^4.2.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "browserslist": [
    "defaults"
  ]
}
